# Copy this file to .env and fill in your Supabase values.
# NEVER commit .env to git.

# Your Supabase project URL (found in Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase SERVICE ROLE key (found in Settings > API > service_role)
# This key bypasses Row Level Security — keep it private.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional: change the local port (default 3131)
# PORT=3131
