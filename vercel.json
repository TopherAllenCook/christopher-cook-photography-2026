{
  "headers": [
    {
      "source": "/(.*\\.(?:css|js|png|jpg|jpeg|webp|svg|ico|woff2?))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/blog-home",    "destination": "/portfolio", "permanent": true },
    { "source": "/blog-home/",   "destination": "/portfolio", "permanent": true },
    { "source": "/blog",         "destination": "/journal",   "permanent": true },
    { "source": "/blog/",        "destination": "/journal",   "permanent": true },
    { "source": "/2022/:path*",  "destination": "/portfolio", "permanent": true },
    { "source": "/2023/:path*",  "destination": "/portfolio", "permanent": true },
    { "source": "/2024/:path*",  "destination": "/portfolio", "permanent": true }
  ],
  "rewrites": [
    { "source": "/journal/:slug", "destination": "/post.html" }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
